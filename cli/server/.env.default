# env defaults

JWT_SECRET=no default
GAME_SERVER_HOST=127.0.0.1
GAME_SERVER_PORT=8080
GAME_DB_STORAGE=memory (storage backend, allowed: memory, sqlite)
GAME_DB_PATH=./_local/db.sqlite3 (sqlite database file path, used when storage is sqlite)
GAME_DB_DRIVER=sqlite (sql driver name, the driver must be linked into the build)
